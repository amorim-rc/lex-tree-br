                                    content: "Sucessão por força da lei.",
                                    children: [
                                        { name: "Capítulo I - Ordem da Vocação Hereditária", label: "Cap. I", subtitle: "Arts. 1.829 a 1.844", content: "Descendentes, ascendentes, cônjuge sobrevivente e colaterais." },
                                        { name: "Capítulo II - Dos Herdeiros Necessários", label: "Cap. II", subtitle: "Arts. 1.845 a 1.850", content: "Metade dos bens da herança pertencente à legítima." },
                                        { name: "Capítulo III - Do Direito de Representação", label: "Cap. III", subtitle: "Arts. 1.851 a 1.856", content: "Chamamento de parentes do falecido para suceder em todos os direitos." }
                                    ]
                                },
                                { 
                                    name: "Título III - Da Sucessão Testamentária", 
                                    label: "Título III", 
                                    subtitle: "Arts. 1.857 a 1.990", 
                                    content: "Sucessão baseada na última vontade do falecido.",
                                    children: [
                                        { name: "Capítulos I a V - Do Testamento", label: "Cap. I-V", subtitle: "Arts. 1.857 a 1.896", content: "Capacidade para testar, formas ordinárias e especiais de testamento e codicilos." },
                                        { name: "Capítulos VI a IX - Disposições e Legados", label: "Cap. VI-IX", subtitle: "Arts. 1.897 a 1.960", content: "Disposições testamentárias, legados, direito de acrescer e substituições." },
                                        { name: "Capítulos X a XIV - Deserdação e Revogação", label: "Cap. X-XIV", subtitle: "Arts. 1.961 a 1.990", content: "Deserdação, redução das disposições, revogação, rompimento e o testamenteiro." }
                                    ]
                                },
                                { 
                                    name: "Título IV - Do Inventário e da Partilha", 
                                    label: "Título IV", 
                                    subtitle: "Arts. 1.991 a 2.027", 
                                    content: "Procedimentos para apuração e divisão do acervo hereditário.",
                                    children: [
                                        { name: "Capítulos I a III - Inventário e Dívidas", label: "Cap. I-III", subtitle: "Arts. 1.991 a 1.996", content: "Administração do espólio, bens sonegados e pagamento das dívidas." },
                                        { name: "Capítulos IV a VII - Partilha", label: "Cap. IV-VII", subtitle: "Arts. 2.002 a 2.027", content: "Colação, regras da partilha, garantia dos quinhões e anulação da partilha." }
                                    ]
                                }
                            ]
                        }
                    ]
                },
                {
                    name: "Livro Complementar",
                    label: "Livro Comp.",
                    subtitle: "Arts. 2.028 a 2.046",
                    content: "Das Disposições Finais e Transitórias. Trata da transição e aplicação das regras do novo Código Civil (2002) em relação ao antigo (1916)."
                }
            ]
        };

        // Configuração do D3.js
        const container = document.getElementById('tree-container');
        const width = container.clientWidth;
        const height = container.clientHeight;

        // Variáveis de estado
        let i = 0;
        const duration = 400; // Duração da animação
        let root;
        let selectedNode = null;

        // Cria o elemento SVG
        const svg = d3.select("#tree-container").append("svg")
            .attr("width", "100%")
            .attr("height", "100%")
            .call(d3.zoom()
                .scaleExtent([0.5, 3]) // Limites de zoom
                .on("zoom", (event) => {
                    svgGroup.attr("transform", event.transform);
                })
            )
            .on("dblclick.zoom", null); // Desabilita zoom no duplo clique

        // Grupo principal que será transformado com o pan/zoom
        const svgGroup = svg.append("g")
            .attr("transform", `translate(${width / 5}, ${height / 2})`);

        // Cria a hierarquia de dados
        root = d3.hierarchy(civilCodeData, d => d.children);
        root.x0 = 0;
        root.y0 = 0;
        selectedNode = root;

        // Recolhe todos os nós no nível 2 (Parte Especial, etc.) para visualização inicial mais limpa
        root.children.forEach(child => {
            if (child.data.label === "Parte Especial") {
                collapse(child);
            } else if (child.children) {
                // Deixa Livro I da parte geral aberto, mas fecha o resto
                child.children.forEach(grandchild => {
                     collapse(grandchild);
                });
            }
        });

        // Função recursiva para fechar nós
        function collapse(d) {
            if (d.children) {
                d._children = d.children;
                d._children.forEach(collapse);
                d.children = null;
            }
        }

        // Renderiza a árvore inicial
        update(root);
        updatePanel(root.data);

        function update(source) {
            // Layout da árvore (horizontal)
            // nodeSize: [espaçamento vertical, espaçamento horizontal]
            const treeLayout = d3.tree().nodeSize([45, 180]);
            
            // Calcula as posições x e y de todos os nós
            treeLayout(root);

            const nodes = root.descendants();
            const links = root.descendants().slice(1);

            // Transforma x/y para a árvore crescer para a direita (horizontal)
            // O D3 d3.tree() orienta de cima para baixo. Trocamos x e y.
            nodes.forEach(d => {
                // Salva a posição alvo (y é a profundidade/horizontal, x é o vertical)
                d.targetY = d.depth * 180;
                d.targetX = d.x; 
            });

            // ================= LIGAÇÕES (LINKS) =================
            const link = svgGroup.selectAll("path.link")
                .data(links, d => d.id);

            const linkEnter = link.enter().insert("path", "g")
                .attr("class", "link")
                .attr("d", d => {
                    const o = { targetX: source.x0, targetY: source.y0 };
                    return diagonal(o, o);
                });

            const linkUpdate = linkEnter.merge(link);

            linkUpdate.transition()
                .duration(duration)
                .attr("d", d => diagonal(d.parent, d));

            link.exit().transition()
                .duration(duration)
                .attr("d", d => {
                    const o = { targetX: source.targetX, targetY: source.targetY };
                    return diagonal(o, o);
                })
                .remove();

            // ================= NÓS (NODES) =================
            const node = svgGroup.selectAll("g.node")
                .data(nodes, d => d.id || (d.id = ++i));

            const nodeEnter = node.enter().append("g")
                .attr("class", "node cursor-pointer")
                .attr("transform", d => `translate(${source.y0},${source.x0})`)
                .on("click", click);

            // Retângulos arredondados para os nós
            nodeEnter.append("rect")
                .attr("width", 90)
                .attr("height", 32)
                .attr("y", -16) // centraliza o retângulo no eixo vertical
                .attr("rx", 16) // cantos arredondados
                .attr("ry", 16)
                .style("fill", "#fff")
                .style("stroke", "#94a3b8")
                .style("stroke-width", "1.5px");

            // Textos dentro dos nós
            nodeEnter.append("text")
                .attr("dy", "0.35em") // centralização vertical
                .attr("x", 45) // centro do retângulo de 90px
                .attr("text-anchor", "middle")
                .text(d => d.data.label)
                .style("font-size", "12px")
                .style("font-weight", "600")
                .style("fill", "#334155")
                .style("pointer-events", "none");

            const nodeUpdate = nodeEnter.merge(node);

            // Atualiza cores baseado no estado de seleção e se tem filhos ocultos
            nodeUpdate.select("rect")
                .transition().duration(duration)
                .style("fill", d => {
                    if (d === selectedNode) return "#334155"; // Nó selecionado (Escuro)
                    return d._children ? "#e2e8f0" : "#ffffff"; // Tem filhos ocultos? (Cinza claro)
                })
                .style("stroke", d => d === selectedNode ? "#1e293b" : "#94a3b8")
                .style("stroke-width", d => d === selectedNode ? "2px" : "1.5px");

            // Atualiza cor do texto
            nodeUpdate.select("text")
                .transition().duration(duration)
                .style("fill", d => d === selectedNode ? "#ffffff" : "#334155");

            // Transição dos nós para suas novas posições
            nodeUpdate.transition()
                .duration(duration)
                .attr("transform", d => `translate(${d.targetY},${d.targetX})`);

            // Transição de saída dos nós (quando fechados)
            const nodeExit = node.exit().transition()
                .duration(duration)
                .attr("transform", d => `translate(${source.targetY},${source.targetX})`)
                .remove();

            nodeExit.select("rect").attr("width", 0).attr("height", 0);
            nodeExit.select("text").style("fill-opacity", 0);

            // Guarda as posições antigas para animação futura
            nodes.forEach(d => {
                d.x0 = d.targetX;
                d.y0 = d.targetY;
            });
        }

        // Desenha as curvas bezier conectando os nós
        function diagonal(s, d) {
            return `M ${s.targetY + 90} ${s.targetX}
                    C ${(s.targetY + 90 + d.targetY) / 2} ${s.targetX},
                      ${(s.targetY + 90 + d.targetY) / 2} ${d.targetX},
                      ${d.targetY} ${d.targetX}`;
        }

        // Função acionada ao clicar em um nó
        function click(event, d) {
            selectedNode = d; // Define como o nó ativo

            // Atualiza o painel inferior de leitura
            updatePanel(d.data);

            // Lógica de expandir/fechar filhos
            if (d.children) {
                // Fecha o nó
                d._children = d.children;
                d.children = null;
            } else {
                // Abre o nó
                d.children = d._children;
                d._children = null;
            }

            update(d);
            
            // Centraliza levemente a visualização no nó clicado
            const transform = d3.zoomTransform(svg.node());
            const newX = -d.targetY * transform.k + width / 4;
            const newY = -d.targetX * transform.k + height / 2;
            
            svg.transition().duration(600).call(
                d3.zoom().transform, 
                d3.zoomIdentity.translate(newX, newY).scale(transform.k)
            );
        }

        // Atualiza os textos do painel de conteúdo
        function updatePanel(data) {
            const panel = document.getElementById('content-panel');
            const title = document.getElementById('node-title');
            const subtitle = document.getElementById('node-subtitle');
            const text = document.getElementById('node-text');

            // Efeito de fade out/in
            panel.style.opacity = 0;
            
            setTimeout(() => {
                title.textContent = data.name;
                subtitle.textContent = data.subtitle;
                
                // Formata o texto preservando quebras de linha para os incisos
                text.innerHTML = data.content.replace(/\n/g, "<br>");
                
                panel.style.opacity = 1;
            }, 150);
        }
    </script>
</body>
</html>
